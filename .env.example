# Meta / WhatsApp Cloud API
WA_PHONE_NUMBER_ID=             # sender phone number ID
WA_ACCESS_TOKEN=                # permanent system-user token
WA_APP_SECRET=                  # for X-Hub-Signature-256 verification
WA_VERIFY_TOKEN=                # arbitrary string; must match Meta webhook config
WA_RECEPTION_TEMPLATE=          # approved Utility template for reception AND staff
                                # notifs (café orders + guardian/coach reminders)
                                # when the 24h window is closed (2 body variables:
                                # {{1}} subject, {{2}} flattened detail).
                                # naming convention: awa_<audience>_<objet>,
                                # e.g. awa_notification. Empty = staff/out-of-window
                                # sends fail 131047 (visible in /admin/notifications).
WA_RECEPTION_TEMPLATE_LANG=fr   # language code of that template
WA_WAITLIST_TEMPLATE=           # approved Utility template when a waitlisted spot
                                # frees up outside the 24h window (2 body vars:
                                # {{1}} class name, {{2}} date/time). Empty =
                                # free-text only. Free text is tried first; template
                                # only on Meta error 131047. Set AFTER Meta approval.
WA_WAITLIST_TEMPLATE_LANG=en    # must match the Meta template language code exactly
                                # (en, en_US, fr, …)

# Wix
WIX_API_KEY=
WIX_SITE_ID=

# Wave
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=            # HMAC verification of Wave webhooks

# Orange Money / Max It (Sonatel) — all three required to enable rails
# (empty = Wave-only). Same portal app as the website is OK.
OM_CLIENT_ID=
OM_CLIENT_SECRET=
OM_MERCHANT_CODE=               # 6-digit merchant code (e.g. 553651)
OM_API_BASE=https://api.orange-sonatel.com
# OM_SANDBOX_CLIENT_ID=
# OM_SANDBOX_CLIENT_SECRET=

# Anthropic
ANTHROPIC_API_KEY=

# Voice-note transcription (optional — without it, voice notes get a polite
# "please type it" reply)
OPENAI_API_KEY=                 # sk-... (platform.openai.com)
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Email notifications to reception (optional — events are still logged + in the
# daily summary without it). Brevo HTTP API: SMTP is blocked on Railway.
BREVO_API_KEY=                  # xkeysib-... (Brevo → Settings → SMTP & API)
EMAIL_FROM=Awa - Revive <support@revive.sn>   # must be a verified Brevo sender
RECEPTION_EMAIL=support@revive.sn

# App
DATABASE_URL=postgres://user:pass@localhost:5432/revive
RECEPTION_PHONE=+221784644329   # human-handoff destination
NEW_CHAT_NOTIFY_PHONE=+221774982711  # WhatsApp pinged when someone starts a conversation (empty = off)
NEW_CHAT_NOTIFY_GAP_HOURS=6     # silence gap (h) after which a message counts as a new conversation
NOTIF_TEST_PHONE=+221774982711  # where /admin/notifications "Envoyer un test" sends (never the real guardian/coach); empty = test disabled
PAYMENT_LINK_TTL_MINUTES=20
BASE_URL=                       # public https URL of this service
STUDIO_ADDRESS=Revive Studio, Dakar
CLAUDE_MODEL=claude-sonnet-5
PORT=3000

# Restricted team accounts for /admin. Unset = fallback revive/revive@5000.
# Comma-separated "user:password" accounts (one per human, for action audit).
ADMIN_USERS=

# Separate owner login: grants the whole admin, including coach payments.
OWNER_ADMIN_USER=owner
OWNER_ADMIN_PASSWORD=
# Deprecated compatibility fallback; remove after migrating the value above.
OWNER_PAYMENTS_PASSWORD=
